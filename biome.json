{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!**/coverage",
      "!**/Noto_Serif_JP_Bold.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/coverage",
      "!**/public/**/*",
      "!**/.DS_Store",
      "!**/.env",
      "!**/.env.*",
      "!**/*.log",
      "!**/kojoall/**/*"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noLabelWithoutControl": {
          "level": "error",
          "options": {
            "inputComponents": ["TextField", "Slider", "Select"]
          }
        }
      }
    },
    "domains": {
      "react": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "bracketSameLine": false,
      "quoteStyle": "double"
    }
  },
  "html": {
    "formatter": {
      "indentScriptAndStyle": false,
      "selfCloseVoidElements": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  }
}
