{
  "name": "client-web-api-sandbox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "markup": "markuplint \"src/**/*.{jsx,tsx,html}\"",
    "markup:fix": "markuplint \"src/**/*.{jsx,tsx,html}\" --fix",
    "check-biome": "biome check",
    "check-biome:fix": "biome check --write",
    "check": "npm run markup && npm run check-biome",
    "check:fix": "npm run markup:fix && npm run check-biome:fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.3.1",
    "@mui/material": "^6.4.5",
    "@mui/x-tree-view": "^8.19.0",
    "@okathira/ghostpdl-wasm": "^1.1.0",
    "@xmldom/xmldom": "^0.8.11",
    "fast-xml-parser": "^5.5.7",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.1.0",
    "jotai": "^2.15.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.4.1",
    "react-xml-viewer": "^3.0.1",
    "three": "^0.174.0",
    "tone": "^15.0.4",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@markuplint/jsx-parser": "^4.7.19",
    "@markuplint/react-spec": "^4.5.14",
    "@testing-library/react": "^16.3.0",
    "@types/dom-mediacapture-transform": "^0.1.11",
    "@types/emscripten": "^1.41.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@types/papaparse": "^5.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.174.0",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "markuplint": "^4.14.1",
    "ts-jest": "^29.2.6",
    "ts-jest-mock-import-meta": "^1.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.2"
  },
  "lint-staged": {
    "*.{jsx,tsx,html}": [
      "markuplint"
    ],
    "src/**/*": [
      "biome check"
    ]
  },
  "volta": {
    "node": "24.14.0"
  }
}
